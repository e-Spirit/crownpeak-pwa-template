{
  "version": "3.0.0",
  "name": "fsxa-nuxt3-pwa",
  "private": true,
  "description": "Demo PWA built with Nuxt 3 and FSXA",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/e-Spirit/crownpeak-pwa-template.git"
  },
  "engines": {
    "npm": ">=10",
    "node": ">=20"
  },
  "scripts": {
    "build": "nuxt build",
    "commit": "npm run lint && git-cz",
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "lint": "eslint --ext .js,.vue,.ts,.tsx --ignore-path .gitignore .",
    "postinstall": "husky install",
    "preview": "nuxt preview",
    "commitmsg": "commitlint -E HUSKY_GIT_PARAMS",
    "release": "release-it",
    "release:ci": "release-it --ci",
    "release:dry-run": "release-it --dry-run",
    "release:ci:dry-run": "release-it --ci --dry-run",
    "start": "node ./.output/server/index.mjs",
    "test": "vitest"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@cypress/webpack-preprocessor": "^7.1.1",
    "@faker-js/faker": "^10.1.0",
    "@nuxt/webpack-builder": "^4.2.1",
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@release-it/conventional-changelog": "^11.0.1",
    "@testing-library/vue": "^8.1.0",
    "@types/ws": "^8.18.1",
    "autoprefixer": "^10.4.22",
    "commitizen": "^4.3.1",
    "cypress": "^15.9.0",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-chai-friendly": "^1.1.0",
    "eslint-plugin-nuxt": "^4.0.0",
    "eslint-plugin-prettier": "^5.5.4",
    "eslint-plugin-vue": "^10.6.0",
    "husky": "^9.1.7",
    "jsdom": "^27.2.0",
    "nuxt": "^4.2.2",
    "nuxt-viewport": "^2.3.1",
    "postcss": "8.5.10",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.1",
    "release-it": "^19.2.3",
    "rollup-plugin-node-polyfills": "^0.2.1",
    "tailwindcss": "^3.4.18",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "vite-plugin-eslint": "^1.8.1",
    "vitest": "^4.0.14",
    "vue-tsc": "^3.1.5"
  },
  "config": {
    "commitizen": {
      "path": "node_modules/cz-conventional-changelog"
    }
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ],
    "rules": {
      "footer-max-line-length": [
        2,
        "always",
        500
      ],
      "body-max-line-length": [
        2,
        "always",
        500
      ]
    }
  },
  "lint-staged": {
    "*.{js,vue,ts,tsx}": "npm run lint"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.1.17",
    "bufferutil": "^4.0.9",
    "fsxa-api": "^11.2.1",
    "fsxa-proxy-api": "^11.0.0",
    "highlight.js": "^11.11.1",
    "reconnecting-websocket": "^4.4.0",
    "utf-8-validate": "^6.0.5",
    "ws": "^8.18.3"
  }
}
